{
    "version": "2.0.0",
    "tasks":[
        {
            "label": "CMake: configure",
            "type": "shell",
            "command": "cmake --preset hello-config-debug",
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: build",
            "type": "shell",
            "command": "cmake --build build/hello-config-debug -- -j" ,
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: clean",
            "type": "shell",
            "command": "find build -mindepth 2 -maxdepth 2 -exec rm -rf {} \\;" ,
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
                        "label": "CMake: clean cache",
            "type": "shell",
            "command": "rm -rf build/hello-config-debug",
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: rebuild (clean + configure + build)",
            "type": "shell",
            "command": "rm -rf build/hello-config-debug && cmake --preset hello-config-debug && cmake --build build/hello-config-debug -- -j",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]   
}