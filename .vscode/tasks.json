{
    "version": "2.0.0",
    "tasks":[
        {
            "label": "CMake: configure stack",
            "type": "shell",
            "command": "cmake --preset stack-debug --log-level=VERBOSE 2>&1",
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: build stack",
            "type": "shell",
            "command": "cmake --build --preset stack-debug 2>&1 | tee build.log" ,
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: configure app",
            "type": "shell",
            "command": "cmake --preset app-debug --log-level=VERBOSE 2>&1",
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: build app",
            "type": "shell",
            "command": "cmake --build --preset stack-app 2>&1 | tee build.log",
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: clean stack",
            "type": "shell",
            "command": "rm -rf build/stack-debug",
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
            }
        },
        {
            "label": "CMake: clean app",
            "type": "shell",
            "command": "rm -rf build/app-debug",
            "group": {
                "kind": "build", // Ctrl+Shift+B will trigger this task
                "isDefault": true
        }
    ]   
}